---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Digital Marketing with AG and our mission.">
  <div class="max-w-3xl mx-auto px-6 py-16 relative">
    <!-- Accent background blobs -->
    <div class="absolute -top-10 -right-10 w-60 h-60 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none -z-10"></div>
    
    <div class="glass-panel rounded-3xl p-8 md:p-10 shadow-xl border border-gray-200/50 dark:border-gray-800/40 relative">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-6 font-heading text-gray-900 dark:text-white">
        About <span class="bg-gradient-to-r from-indigo-500 to-purple-650 bg-clip-text text-transparent">Us</span>
      </h1>
      
      <div class="prose dark:prose-invert max-w-none space-y-6">
        <p class="text-base md:text-lg leading-relaxed text-gray-600 dark:text-gray-300">
          <strong class="text-gray-950 dark:text-white font-bold">Digital Marketing with AG</strong> is a specialized technical resource built for modern creators, software engineers, and digital entrepreneurs navigating the structural shifts of the modern search landscape.
        </p>
        <p class="text-sm md:text-base leading-relaxed text-gray-600 dark:text-gray-400">
          We cover the engineering, marketing, and monetization loop required to win citations across AI answer engines (AEO), generative context loops (GEO), and traditional indexing networks (SEO).
        </p>
        <div class="border-t border-b border-gray-250/20 dark:border-gray-800/40 py-6 my-6 grid sm:grid-cols-2 gap-4">
          <div>
            <h4 class="font-bold text-xs uppercase tracking-wider text-indigo-500 dark:text-indigo-400 mb-1">Our Strategy</h4>
            <p class="text-xs text-gray-500 dark:text-gray-400">Building high-density structured content that search engines and language models can catalog easily.</p>
          </div>
          <div>
            <h4 class="font-bold text-xs uppercase tracking-wider text-purple-500 dark:text-purple-400 mb-1">Our Purpose</h4>
            <p class="text-xs text-gray-500 dark:text-gray-400">Enabling creators to stack ad revenue, micro-referral links, and digital commissions seamlessly.</p>
          </div>
        </div>
        <p class="text-sm md:text-base leading-relaxed text-gray-600 dark:text-gray-400">
          Our core objective is to provide developers and content distributors with concrete, code-first frameworks to transition their web properties into highly optimized, monetizable digital assets.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

