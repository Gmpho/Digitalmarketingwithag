---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Digital Marketing with AG and our mission.">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-6">About</h1>
    <div class="prose prose-gray dark:prose-invert max-w-none">
      <p>
        <strong>Digital Marketing with AG</strong> is a resource for modern marketers, creators, and entrepreneurs
        looking to understand and profit from the evolving digital landscape.
      </p>
      <p>
        We cover the full stack of digital monetization — from traditional SEO to generative engine optimization (GEO),
        answer engine optimization (AEO), social media automation, and passive income strategies.
      </p>
      <p>
        Our goal is to provide clear, actionable frameworks that help you turn online content into sustainable revenue.
      </p>
    </div>
  </div>
</BaseLayout>
