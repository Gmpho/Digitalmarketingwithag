---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

// Calculate reading time
const words = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(words / 200));
---

<BaseLayout title={title} description={description} type="article" publishedTime={pubDate.toISOString()} {tags}>
  <!-- Scroll Progress Indicator -->
  <div id="scroll-progress" class="fixed top-[64px] left-0 h-[3px] bg-gradient-to-r from-indigo-500 to-purple-600 transition-all duration-75 z-[60] w-0"></div>

  <article class="max-w-3xl mx-auto px-6 py-16 relative">
    <!-- Top accent glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-72 h-72 bg-indigo-500/5 rounded-full blur-3xl -z-10 pointer-events-none"></div>

    <!-- Back to blog link -->
    <a href="/blog" class="inline-flex items-center gap-1.5 text-xs font-bold text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors mb-8 group">
      <svg class="w-3.5 h-3.5 transform group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Articles
    </a>

    <header class="mb-12">
      <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500 dark:text-gray-400 mb-4 font-semibold uppercase tracking-wider">
        <span>{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        <span class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-gray-700"></span>
        <span class="text-indigo-500 dark:text-indigo-400">{readingTime} min read</span>
      </div>
      
      <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white leading-tight font-heading mb-4">
        {title}
      </h1>
      
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed font-sans font-medium mb-6">
        {description}
      </p>

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="px-3 py-1 text-xs font-semibold rounded-md border bg-gray-50/50 dark:bg-gray-950/20 text-gray-600 dark:text-gray-400 border-gray-200/60 dark:border-gray-800/40">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose dark:prose-invert max-w-none border-t border-gray-100 dark:border-gray-900/50 pt-10">
      <slot />
    </div>

    <!-- Share block at bottom -->
    <div class="mt-16 pt-8 border-t border-gray-200/50 dark:border-gray-900/30 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="text-sm font-bold text-gray-755 dark:text-gray-300 font-heading">
        Share this article
      </div>
      <div class="flex items-center gap-2">
        <a 
          id="share-twitter" 
          href="#" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="p-2.5 rounded-xl border border-gray-200 dark:border-gray-800/50 hover:border-indigo-500/30 hover:bg-indigo-50/20 dark:hover:bg-indigo-950/20 text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all cursor-pointer"
          aria-label="Share on X"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <a 
          id="share-linkedin" 
          href="#" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="p-2.5 rounded-xl border border-gray-200 dark:border-gray-800/50 hover:border-indigo-500/30 hover:bg-indigo-50/20 dark:hover:bg-indigo-950/20 text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all cursor-pointer"
          aria-label="Share on LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
        <button 
          id="share-copy" 
          class="p-2.5 rounded-xl border border-gray-200 dark:border-gray-800/50 hover:border-indigo-500/30 hover:bg-indigo-50/20 dark:hover:bg-indigo-950/20 text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all cursor-pointer relative"
          aria-label="Copy Link"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
          </svg>
          <span id="copy-toast" class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-gray-900 text-white dark:bg-gray-100 dark:text-gray-950 text-[10px] rounded opacity-0 transition-opacity pointer-events-none font-bold whitespace-nowrap">Link Copied!</span>
        </button>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  function setupArticleFeatures() {
    // Scroll progress logic
    const scrollBar = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      if (scrollBar) {
        scrollBar.style.width = scrolled + '%';
      }
    });

    // Share buttons logic
    const twitterBtn = document.getElementById('share-twitter') as HTMLAnchorElement;
    const linkedinBtn = document.getElementById('share-linkedin') as HTMLAnchorElement;
    const copyBtn = document.getElementById('share-copy');
    const copyToast = document.getElementById('copy-toast');

    const url = encodeURIComponent(window.location.href);
    const text = encodeURIComponent(document.title);

    if (twitterBtn) twitterBtn.href = `https://twitter.com/intent/tweet?url=${url}&text=${text}`;
    if (linkedinBtn) linkedinBtn.href = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;

    copyBtn?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        if (copyToast) {
          copyToast.style.opacity = '1';
          setTimeout(() => {
            copyToast.style.opacity = '0';
          }, 2000);
        }
      });
    });
  }

  setupArticleFeatures();
  document.addEventListener('astro:page-load', setupArticleFeatures);
</script>

