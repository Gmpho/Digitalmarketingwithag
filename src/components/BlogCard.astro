---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const getTagStyles = (tag: string) => {
  const t = tag.toUpperCase();
  if (t === 'SEO' || t === 'AI SEARCH') {
    return 'bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 border-indigo-200/50 dark:border-indigo-900/30';
  } else if (t === 'GEO') {
    return 'bg-purple-500/10 text-purple-600 dark:text-purple-400 border-purple-200/50 dark:border-purple-900/30';
  } else if (t === 'AEO') {
    return 'bg-pink-500/10 text-pink-600 dark:text-pink-400 border-pink-200/50 dark:border-pink-900/30';
  } else if (t === 'MONETIZATION' || t === 'DIGITAL MARKETING') {
    return 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-emerald-200/50 dark:border-emerald-900/30';
  }
  return 'bg-slate-500/10 text-slate-600 dark:text-slate-400 border-slate-200/50 dark:border-slate-800/30';
};
---

<article class="group relative rounded-2xl p-6 glass-panel transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-500/5 hover:border-indigo-500/30 dark:hover:border-indigo-500/20 overflow-hidden flex flex-col justify-between">
  <!-- Glowing subtle gradient in background on hover -->
  <div class="absolute -inset-px bg-gradient-to-r from-indigo-500/5 via-purple-500/5 to-pink-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10 pointer-events-none rounded-2xl"></div>

  <a href={`/blog/${post.id}`} class="block h-full flex flex-col justify-between">
    <div>
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
        </span>
        <span class="text-[11px] font-bold text-indigo-600 dark:text-indigo-400 flex items-center gap-1">
          Read Article
          <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </div>
      
      <h2 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors duration-200 mb-3 leading-snug font-heading">
        {title}
      </h2>
      
      <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4 line-clamp-3">
        {description}
      </p>
    </div>

    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
        {tags.slice(0, 3).map(tag => (
          <span class={`px-2.5 py-0.5 text-xs font-semibold rounded-md border transition-all ${getTagStyles(tag)}`}>
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>

