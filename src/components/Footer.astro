---

const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-bold mb-3">DigitalMarketing<span class="text-indigo-500">AG</span></h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          Strategies, tools, and insights for modern digital monetization.
        </p>
      </div>
      <div>
        <h4 class="font-semibold text-sm mb-3">Quick Links</h4>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
          <li><a href="/" class="hover:text-indigo-500 transition-colors">Home</a></li>
          <li><a href="/blog" class="hover:text-indigo-500 transition-colors">Blog</a></li>
          <li><a href="/about" class="hover:text-indigo-500 transition-colors">About</a></li>
          <li><a href="/contact" class="hover:text-indigo-500 transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold text-sm mb-3">Topics</h4>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
          <li>SEO & GEO</li>
          <li>AEO Optimization</li>
          <li>Social Media Automation</li>
          <li>Digital Monetization</li>
        </ul>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-800 text-center text-sm text-gray-500 dark:text-gray-500">
      &copy; {year} Digital Marketing with AG. All rights reserved.
    </div>
  </div>
</footer>
